{
  "$id": "https://raw.githubusercontent.com/cnstudio-io/cnstudio/main/schemas/v1/rects.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "rects",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema","type","rev","rects"],
