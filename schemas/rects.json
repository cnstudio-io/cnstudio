    "schema": { "const": "https://raw.githubusercontent.com/cnstudio-io/cnstudio/main/schemas/v1/rects.json" },
    "type": { "const": "rects" },
    "rev": { "type": "integer" },
    "rects": { "type": "object", "additionalProperties": { "$ref": "_defs.json#/$defs/Rect" } }
  }
}
